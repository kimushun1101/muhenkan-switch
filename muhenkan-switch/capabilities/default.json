{
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main", "help"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "store:default",
    "autostart:default",
    "updater:default"
  ]
}
